# Breadstick — environment configuration (BYOK: bring your own keys)
#
# Copy this file to `.env` and fill in the keys for the services you use.
# Everything is optional except the core generation keys. Keys live only in
# your `.env` (or the in-browser UI) and are never sent anywhere except the
# provider you're calling. `.env` and `.secrets/` are gitignored — never commit
# real keys.

# ── Core (script + image/video generation) ──────────────────────────────────
ANTHROPIC_API_KEY=
KIE_API_KEY=
OPENAI_API_KEY=
# Optional: override the kie.ai file-upload base URL
KIE_UPLOAD_BASE=

# ── Voice & media (optional) ────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
LIFEJOURNAL_VOICE_ID=

# ── Delivery & social scheduling (optional) ─────────────────────────────────
# Blotato's key is entered in the Blotato node UI, not here.
POSTIZ_API_KEY=
POSTIZ_BASE_URL=
NOTION_API_KEY=
# Path to a Google Service Account JSON you place in .secrets/ (Drive delivery)
GOOGLE_DRIVE_SA_KEY=
DISCORD_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALLOWED_USERS=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ALLOWED_NUMBERS=
CLOUDFLARE_TUNNEL_NAME=
CLOUDFLARE_TUNNEL_HOSTNAME=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Advanced: self-deploy lane (optional) ───────────────────────────────────
# Wire these to enable the voice/agent → GitHub → Vercel deploy flow. Leave
# blank to keep it disabled.
SHIP_TEMPLATE_REPO_PATH=
SHIP_TEMPLATE_REMOTE=
SHIP_TEMPLATE_BRANCH_PREFIX=
SHIP_TEMPLATE_GITHUB_TOKEN=
SHIP_TEMPLATE_VERCEL_TOKEN=
SHIP_TEMPLATE_VERCEL_PROJECT_ID=
SHIP_TEMPLATE_VERCEL_TEAM_ID=
SHIP_TEMPLATE_CLAUDE_BIN=
SHIP_TEMPLATE_CLAUDE_ENV_EXTRA=
